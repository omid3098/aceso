# Health Tracker Bot - Copy to .env and fill in values
# Get BOT_TOKEN from @BotFather on Telegram
BOT_TOKEN=your_bot_token_here

# Comma-separated Telegram user IDs allowed to use the bot
ADMIN_IDS=123456789,987654321

# IANA timezone (e.g. Asia/Tehran, Europe/London, US/Eastern, UTC)
TIMEZONE=UTC

# Scheduled reminder times (HH:MM in the configured timezone)
REMINDER_NOON=12:00
REMINDER_NIGHT=21:00
